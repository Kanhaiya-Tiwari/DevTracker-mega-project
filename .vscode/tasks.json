{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run DevTrackr Stack",
			"type": "shell",
			"command": "env",
			"args": [
				"POSTGRES_PASSWORD=devtrackr",
				"JWT_SECRET=devtrackr_secret",
				"docker",
				"compose",
				"-f",
				"infra/docker-compose.yml",
				"up",
				"--build"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run DevTrackr Stack",
			"type": "shell",
			"command": "POSTGRES_PASSWORD=devtrackr JWT_SECRET=devtrackr_secret docker compose -f infra/docker-compose.yml up --build",
			"isBackground": true,
			"group": "build"
		}
	]
}